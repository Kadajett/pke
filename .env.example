# PKE Configuration
# All variables are prefixed with PKE_

# Qdrant
PKE_QDRANT_URL=http://localhost:6333
PKE_QDRANT_COLLECTION=pke

# Ollama
PKE_OLLAMA_URL=http://localhost:11434
PKE_OLLAMA_EMBED_MODEL=nomic-embed-text

# Obsidian vault path
PKE_OBSIDIAN_VAULT_PATH=~/Documents/Journal

# GitHub repos to index (comma-separated)
PKE_GITHUB_REPOS=["Kadajett/pke"]

# Discord
PKE_DISCORD_BOT_TOKEN=
PKE_DISCORD_CHANNEL_IDS=[]

# Sync state database path
PKE_SYNC_DB_PATH=data/sync_state.db

# API server
PKE_API_HOST=0.0.0.0
PKE_API_PORT=8000

# Docker Compose: host path for Obsidian vault mount
OBSIDIAN_VAULT_PATH=~/Documents/Journal
